# Claude Code Configuration
# Copy to .env.production and fill in your values

# Project settings
COMPOSE_PROJECT_NAME=claude-code

# Authentication (use ONE of these)
# Option 1: API key (charges API account, good for automation)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Option 2: OAuth token for Claude Pro/Max subscription (no per-request charges)
# Generate once with: claude setup-token
# CLAUDE_CODE_OAUTH_TOKEN=clt-oauth-xxxxxxxxxxxxxxxxxxxxxxxxx

# Git repository (SSH URL for deploy key auth)
# GIT_REPO=git@github.com:your-org/your-repo.git
# GIT_BRANCH=main

# Git commit identity
# GIT_USER_NAME=Claude Code
# GIT_USER_EMAIL=claude@example.com

# Path to SSH deploy key file (used by Docker Compose secrets)
# Generate with: ssh-keygen -t ed25519 -f deploy_key -N ""
# Then add deploy_key.pub as a deploy key to your GitHub repo (with write access)
# DEPLOY_KEY_PATH=./deploy_key

# Optional: Override default model
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: One-time init command (e.g., install dev dependencies)
# INIT_COMMAND=apt-get update && apt-get install -y build-essential python3

# Optional: Extra flags for claude remote-control
# CLAUDE_EXTRA_ARGS=--allowedTools "Bash,Read,Edit"

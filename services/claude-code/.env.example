# Claude Code Configuration
# Copy to .env.production and fill in your values

# Project settings
COMPOSE_PROJECT_NAME=claude-code

# Git repository (SSH URL for deploy key auth)
# GIT_REPO=git@github.com:your-org/your-repo.git
# GIT_BRANCH=main

# Git commit identity
# GIT_USER_NAME=Claude Code
# GIT_USER_EMAIL=claude@example.com

# SSH deploy key (base64-encoded private key, single line)
# Generate key:    ssh-keygen -t ed25519 -f deploy_key -N ""
# Add deploy_key.pub to your GitHub repo (Settings > Deploy keys, enable write access)
# Encode for env:  base64 < deploy_key | tr -d '\n'
# DEPLOY_KEY_B64=

# Permission mode: default, acceptEdits, bypassPermissions
# - acceptEdits (default): auto-approves file edits, prompts for commands
# - bypassPermissions:     full YOLO mode — no prompts, fully autonomous
# CLAUDE_PERMISSION_MODE=acceptEdits

# Optional: Override default model
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: One-time init command (e.g., install dev dependencies)
# INIT_COMMAND=apt-get update && apt-get install -y build-essential python3

# Optional: Extra flags for claude remote-control
# CLAUDE_EXTRA_ARGS=--allowedTools "Bash,Read,Edit"

relay:
  upstream: "http://web:9000/"
  host: 0.0.0.0
  port: 3000
  # Credentials are generated via: docker compose run --rm relay credentials generate
  # Copy the output secret_key and public_key here:
  secret_key: "!!changeme!!"
  public_key: "!!changeme!!"
logging:
  level: WARN
processing:
  enabled: true
  kafka_config:
    - {name: "bootstrap.servers", value: "kafka:9092"}
    - {name: "message.max.bytes", value: 50000000}
  redis: redis://redis:6379
  geoip_path: "/geoip/GeoLite2-City.mmdb"

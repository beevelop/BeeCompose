SENTRY_SECRET_KEY=!!changeme!!-generate-with-sentry-config-generate-secret-key
SENTRY_SYSTEM_SECRET_KEY=!!changeme!!-generate-with-sentry-config-generate-secret-key
SENTRY_EVENT_RETENTION_DAYS=90
SENTRY_SERVER_EMAIL=noreply@example.com
SENTRY_EMAIL_HOST=smtp.example.com
SENTRY_EMAIL_PORT=587

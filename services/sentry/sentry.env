# Sentry runtime environment variables
# Loaded by all sentry-* containers via env_file in docker-compose.yml

# REQUIRED: Generate a unique secret key before starting Sentry.
# Run: docker compose run --rm web config generate-secret-key
# Then replace !!changeme!! below with the generated value.
# WARNING: Starting Sentry with the placeholder value will cause a startup error.
SENTRY_SECRET_KEY=!!changeme!!

# Event retention (days)
SENTRY_EVENT_RETENTION_DAYS=90

# Mail hostname — used to build the From address: sentry@<SENTRY_MAIL_HOST>
# SENTRY_MAIL_HOST=sentry.example.com

# Sentry runtime environment variables
# Loaded by all sentry-* containers via env_file in docker-compose.yml

# REQUIRED: Generate with: docker compose run --rm web config generate-secret-key
SENTRY_SYSTEM_SECRET_KEY=!!changeme!!

# Event retention ( also set in .env.exampledays) 
SENTRY_EVENT_RETENTION_DAYS=90

# Mail  used to build the From address: sentry@<SENTRY_MAIL_HOST>hostname 
# SENTRY_MAIL_HOST=sentry.example.com

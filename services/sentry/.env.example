# Public domain for Sentry (used by Traefik routing + system.url-prefix)
SERVICE_DOMAIN=sentry.example.com

# Set to "feature-complete" to enable transactions, metrics, profiling, replays, monitors, uptime
# Default "errors-only" runs ~26 containers and requires ~8 GB RAM
COMPOSE_PROFILES=errors-only

# Event data retention in days
SENTRY_EVENT_RETENTION_DAYS=90

# FQDN used as the mail domain (e.g. From: sentry@example.com)
SENTRY_MAIL_HOST=example.com

# Max external source map file size (e.g. 1M, 10M)
SENTRY_MAX_EXTERNAL_SOURCEMAP_SIZE=1M

# Parallel task worker processes (4-32 recommended)
SENTRY_TASKWORKER_CONCURRENCY=4

# Override the postgres username if needed (default: postgres)
# POSTGRES_USER=postgres

# Statsd address for metrics (optional)
# STATSD_ADDR=127.0.0.1:8125
